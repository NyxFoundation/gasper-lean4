  (vset : Hash → Finset Validator) (parent : HashParent Hash) (genesis : Hash) (st : State Validator Hash),
  QuorumContext τ stake vset →
    two_thirds_good τ stake vset st →
      Not (q_intersection_slashed τ stake vset st) →
